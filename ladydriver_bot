import logging
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import (
    Application, CommandHandler, MessageHandler,
    CallbackQueryHandler, ConversationHandler, filters, ContextTypes
)

BOT_TOKEN = "8153371774:AAGYiqq5IrwyTXAzcauYxBY4L5mFKTN70hc"
DRIVER_GROUP_ID = -483191317
BASE_PRICE = 8500

NAME, PHONE, FROM_ADDR, TO_ADDR, CONFIRM = range(5)

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)


async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data.clear()
    await update.message.reply_text(
        "Privet! Ya bot servisa LadyDriver - zhenskiy trezvyy voditel v Almaty.\n\n"
        "Oformlu zakaz za 1 minutu!\n\n"
        "Kak vas zovut?"
    )
    return NAME


async def get_name(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["name"] = update.message.text.strip()
    await update.message.reply_text(
        "Priyatno poznakomitsya, " + context.user_data["name"] + "!\n\n"
        "Vvedite vash nomer telefona:\n(naprimer: +7 777 123 45 67)"
    )
    return PHONE


async def get_phone(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["phone"] = update.message.text.strip()
    await update.message.reply_text(
        "Otkuda vas zabrat?\n\n"
        "Napishite adres ili nazvanie zavedeniya:"
    )
    return FROM_ADDR


async def get_from(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["from_addr"] = update.message.text.strip()
    await update.message.reply_text(
        "Kuda edem?\n\n"
        "Vvedite adres naznacheniya:"
    )
    return TO_ADDR


async def get_to(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["to_addr"] = update.message.text.strip()
    d = context.user_data

    keyboard = InlineKeyboardMarkup([
        [InlineKeyboardButton("Podtverdit zakaz", callback_data="confirm")],
        [InlineKeyboardButton("Otmenit", callback_data="cancel")],
    ])

    await update.message.reply_text(
        "Proverite zakaz:\n\n"
        "Imya: " + d["name"] + "\n"
        "Telefon: " + d["phone"] + "\n"
        "Otkuda: " + d["from_addr"] + "\n"
        "Kuda: " + d["to_addr"] + "\n"
        "Stoimost: " + str(BASE_PRICE) + " tenge\n\n"
        "Oplata nalichnymi ili Kaspi posle poezdki.",
        reply_markup=keyboard
    )
    return CONFIRM


async def confirm_order(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()

    if query.data == "cancel":
        await query.edit_message_text("Zakaz otmenen. Nazhite /start chtoby nachat zanovo.")
        return ConversationHandler.END

    d = context.user_data
    client_id = query.from_user.id
    order_id = f"{client_id % 10000:04d}"

    context.bot_data[f"order_{order_id}"] = client_id

    await query.edit_message_text(
        "Zakaz prinyat!\n\n"
        "My uzhe ishchem blizhayshego voditelya.\n"
        "Vy poluchite uvedomlenie, kak tolko voditel budet naznachen.\n\n"
        "Srednee vremya ozhidaniya: 10-15 minut"
    )

    driver_keyboard = InlineKeyboardMarkup([
        [InlineKeyboardButton("Vzyat zakaz", callback_data=f"take_{order_id}_{client_id}")]
    ])

    await context.bot.send_message(
        chat_id=DRIVER_GROUP_ID,
        text=(
            "NOVYY ZAKAZ #" + order_id + "\n\n"
            "Klient: " + d["name"] + "\n"
            "Telefon: " + d["phone"] + "\n"
            "Otkuda: " + d["from_addr"] + "\n"
            "Kuda: " + d["to_addr"] + "\n"
            "Summa: " + str(BASE_PRICE) + " tenge\n\n"
            "Pervaya, kto nazhmyot - beryot zakaz!"
        ),
        reply_markup=driver_keyboard
    )

    return ConversationHandler.END


async def take_order(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()

    parts = query.data.split("_")
    order_id = parts[1]
    client_id = int(parts[2])

    driver = query.from_user
    driver_name = driver.first_name or "Voditel"
    driver_username = f"@{driver.
username}" if driver.username else "net username"

    await query.edit_message_text(
        query.message.text + "\n\nVzyala: " + driver_name + " (" + driver_username + ")"
    )

    try:
        await context.bot.send_message(
            chat_id=client_id,
            text=(
                "Voditel naznachen!\n\n"
                "Imya: " + driver_name + "\n"
                "Kontakt: " + driver_username + "\n\n"
                "Voditel uzhe vyekhala k vam!"
            )
        )
    except Exception as e:
        logger.error(f"Error notifying client {client_id}: {e}")


async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Zakaz otmenen. Nazhite /start chtoby nachat zanovo.")
    return ConversationHandler.END


def main():
    app = Application.builder().token(BOT_TOKEN).build()

    conv = ConversationHandler(
        entry_points=[CommandHandler("start", start)],
        states={
            NAME:      [MessageHandler(filters.TEXT & ~filters.COMMAND, get_name)],
            PHONE:     [MessageHandler(filters.TEXT & ~filters.COMMAND, get_phone)],
            FROM_ADDR: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_from)],
            TO_ADDR:   [MessageHandler(filters.TEXT & ~filters.COMMAND, get_to)],
            CONFIRM:   [CallbackQueryHandler(confirm_order, pattern="^(confirm|cancel)$")],
        },
        fallbacks=[CommandHandler("cancel", cancel)],
    )

    app.add_handler(conv)
    app.add_handler(CallbackQueryHandler(take_order, pattern=r"^take_"))

    print("LadyDriver bot started!")
    app.run_polling()


if __name__ == "__main__":
    main()
