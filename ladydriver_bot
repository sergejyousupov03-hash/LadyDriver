# -*- coding: utf-8 -*
import logging
import os
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import (
    Application, CommandHandler, MessageHandler,
    CallbackQueryHandler, ConversationHandler, filters, ContextTypes
)
BOT_TOKEN = os.environ.get("BOT_TOKEN", "YOUR_TOKEN_HERE")
DRIVER_GROUP_ID = int(os.environ.get("DRIVER_GROUP_ID", "-1001234567890"))
BASE_PRICE = 8500
NAME, PHONE, FROM_ADDR, TO_ADDR, CONFIRM = range(5)
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data.clear()
    await update.message.reply_text(
        "\U0001f44b Привет! Я бот сервиса LadyDriver\n"
        "Женский трезвый водитель в Алматы \U0001f697\n\n"
        "Оформлю заказ за 1 минуту!\n\n"
        "Как 
вас зовут?"
    )
    return NAME
async def get_name(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["name"] = update.message.text.strip()
    await update.message.reply_text(
        "Приятно познакомиться, " + context.user_data["name"] + "! \U0001f60a\n\n"
        "Введите ваш номер телефона:\n(например: +7 777 123 45 67)"
    )
    return PHONE
async def get_phone(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["phone"] = update.message.text.strip()
    await update.message.reply_text(
        "\U0001f4cd Откуда вас забрать?\n\n"
        "Напишите адрес или название заведения:"
    )
    return FROM_ADDR
async def get_from(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["from_addr"] = update.message.text.strip()
    await update.message.reply_text(
        "\U0001f3c1 Куда едем?\n\n"
        "Введите адрес назначения:"
    )
    return TO_ADDR
async def get_to(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["to_addr"] = update.message.text.strip()
    d = context.user_data
    keyboard = InlineKeyboardMarkup([
        [InlineKeyboardButton("\u2705 Подтвердить заказ", callback_data="confirm")],
        [InlineKeyboardButton("\u274c Отменить", callback_data="cancel")],
    ])
    text = (
        "\U0001f4cb Проверьте заказ:\n\n"
        "\U0001f464 Имя: " + d["name"] + "\n"
        "\U0001f4de Телефон: " + d["phone"] + "\n"
        "\U0001f4cd Откуда: " + d["from_addr"] + "\n"
        "\U0001f3c1 Куда: " + d["to_addr"] + "\n"
        "\U0001f4b0 Стоимость: " + str(BASE_PRICE) + " тенге\n\n"
        "\U0001f512 Оплата наличными или Kaspi после поездки."
    )
    await update.message.reply_text(text, reply_markup=keyboard)
    return CONFIRM
async def confirm_order(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    if query.data == "cancel":
        await query.edit_message_text("Заказ отменён. Нажмите /start чтобы начать заново.")
        return ConversationHandler.END
    d = context.user_data
    client_id = query.from_user.id
    order_id = str(client_id % 10000).zfill(4)
    context.bot_data["order_" + order_id] = client_id
    await query.edit_message_text(
        "\U0001f389 Заказ принят!\n\n"
        "Ищем ближайшего водителя...\n"
        "Среднее время ожидания: 10-15 минут \U0001f338"
    )
    driver_keyboard = InlineKeyboardMarkup([
        [InlineKeyboardButton("\U0001f697 Взять заказ", callback_data="take_" + order_id + "_" + str(client_id))]
    ])
    msg = (
        "\U0001f195 НОВЫЙ ЗАКАЗ #" + order_id + "\n\n"
        "\U0001f464 Клиент: " + d["name"] + "\n"
        "\U0001f4de Телефон: " + d["phone"] + "\n"
        "\U0001f4cd Откуда: " + d["from_addr"] + "\n"
        "\U0001f3c1 Куда: " + d["to_addr"] + "\n"
        "\U0001f4b0 Сумма: " + str(BASE_PRICE) + " тенге\n\n"
        "Первая, кто нажмёт — берёт заказ!"
    )
    await context.bot.send_message(
        chat_id=DRIVER_GROUP_ID,
        text=msg,
        reply_markup=driver_keyboard
    )
    return ConversationHandler.END
async def take_order(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    parts = query.data.split("_")
    client_id = int(parts[2])
    driver = query.from_user
    driver_name = driver.first_name or "Водитель"
    driver_username = "@" + driver.username if driver.username else "нет username"
    await query.edit_message_text(
        query.message.text + "\n\n\u2705 Взяла: " + driver_name + " (" + driver_username + ")"
    )
    try:
        await context.bot.send_message(
            chat_id=client_id,
            text=(
                "\u2705 
Водитель назначен!\n\n"
                "Имя: " + driver_name + "\n"
                "Контакт: " + driver_username + "\n\n"
                "Водитель уже выехала к вам! \U0001f338"
            )
        )
    except Exception as e:
        logger.error("Error notifying client: " + str(e))
async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Заказ отменён. Нажмите /start чтобы начать заново.")
    return ConversationHandler.END
def main():
    app = Application.builder().token(BOT_TOKEN).build()
    conv = ConversationHandler(
        entry_points=[CommandHandler("start", start)],
        states={
            NAME:      [MessageHandler(filters.TEXT & ~filters.COMMAND, get_name)],
            PHONE:     [MessageHandler(filters.TEXT & ~filters.COMMAND, get_phone)],
            FROM_ADDR: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_from)],
            TO_ADDR:   [MessageHandler(filters.TEXT & ~filters.COMMAND, get_to)],
            CONFIRM:   [CallbackQueryHandler(confirm_order, pattern="^(confirm|cancel)$")],
        },
        fallbacks=[CommandHandler("cancel", cancel)],
    )
    app.add_handler(conv)
    app.add_handler(CallbackQueryHandler(take_order, pattern="^take_"))
    print("LadyDriver bot started!")
    app.run_polling(drop_pending_updates=True)
if __name__ == "__main__":
    main()
